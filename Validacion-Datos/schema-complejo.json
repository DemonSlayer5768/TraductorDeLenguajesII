{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "user": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "profile": {
          "type": "object",
          "properties": {
            "firstName": {
              "type": "string",
              "minLength": 2,
              "maxLength": 30
            },
            "lastName": {
              "type": "string",
              "minLength": 2,
              "maxLength": 30
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "phone": {
              "type": "string",
              "pattern": "^\\+?[1-9]\\d{1,14}$"
            },
            "birthDate": {
              "type": "string",
              "format": "date"
            }
          },
          "required": ["firstName", "lastName", "email"]
        },
        "preferences": {
          "type": "object",
          "properties": {
            "theme": {
              "enum": ["light", "dark", "auto"]
            },
            "notifications": {
              "type": "boolean"
            },
            "language": {
              "type": "string",
              "enum": ["es", "en", "fr"]
            }
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20
          },
          "uniqueItems": true,
          "maxItems": 10
        }
      },
      "required": ["id", "profile"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    }
  },
  "required": ["user"]
}